{
  "name": "claude-mcp-tunnel",
  "version": "1.0.0",
  "description": "MCP server that exposes local dev servers to your phone via Claude Desktop. Auto-detects frameworks, starts servers, creates tunnels. Zero accounts, zero config.",
  "author": "AustinRyan",
  "license": "MIT",
  "bin": {
    "devgate": "./bin/devgate.js"
  },
  "main": "./src/index.js",
  "keywords": [
    "tunnel",
    "localhost",
    "expose",
    "dev-server",
    "mobile",
    "qr-code",
    "bore",
    "ngrok-alternative",
    "claude-code",
    "mcp"
  ],
  "scripts": {
    "start": "node bin/devgate.js",
    "mcp": "node mcp-server/index.js",
    "test": "node test/test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "localtunnel": "^2.0.2",
    "qrcode-terminal": "^0.12.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AustinRyan/claude-mcp-tunnel"
  }
}
