{
  "name": "claude-mcp-tunnel",
  "version": "1.1.0",
  "description": "MCP server that exposes local dev servers to your phone via Claude Desktop. Auto-detects frameworks, starts servers, creates tunnels. Zero accounts, zero config.",
  "author": "AustinRyan",
  "license": "MIT",
  "bin": {
    "claude-mcp-tunnel": "bin/devgate.js",
    "claude-mcp-tunnel-server": "mcp-server/index.js"
  },
  "main": "./src/index.js",
  "files": [
    "bin/",
    "src/",
    "mcp-server/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "claude",
    "tunnel",
    "cloudflare",
    "localhost",
    "expose",
    "dev-server",
    "mobile",
    "ngrok-alternative",
    "model-context-protocol",
    "claude-desktop"
  ],
  "scripts": {
    "start": "node bin/devgate.js",
    "mcp": "node mcp-server/index.js",
    "test": "node test/test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "localtunnel": "^2.0.2",
    "qrcode-terminal": "^0.12.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AustinRyan/claude-mcp-tunnel.git"
  }
}
